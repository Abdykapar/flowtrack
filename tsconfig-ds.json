{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src/app/components/ui",
    "outDir": "./dist-types",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "skipLibCheck": true
  },
  "include": ["src/app/components/ui/**/*.ts", "src/app/components/ui/**/*.tsx"],
  "exclude": ["node_modules"]
}
